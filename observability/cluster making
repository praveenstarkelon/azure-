Kind Cluster banao


cat > ~/kind-config.yaml << EOF
kind: Cluster
apiVersion: kind.x-k8s.io/v1alpha4
nodes:
  - role: control-plane
  - role: worker
  - role: worker
  - role: worker
EOF

kind create cluster \
  --name observability-test \
  --config ~/kind-config.yaml

kubectl get nodes
