===============================================================================
Umbrella Chart banao

mkdir ~/my-observability
cd ~/my-observability

=================================================================================
Chart.yaml

cat > Chart.yaml << EOF
apiVersion: v2
name: my-observability
description: Complete observability stack
version: 1.0.0
dependencies:
  - name: kube-prometheus-stack
    version: "79.12.0"
    repository: https://prometheus-community.github.io/helm-charts
  - name: loki-stack
    version: "2.10.3"
    repository: https://grafana.github.io/helm-charts
  - name: grafana
    version: "10.3.0"
    repository: https://grafana.github.io/helm-charts
  - name: reloader
    version: "2.2.9"
    repository: https://stakater.github.io/stakater-charts
  - name: kubernetes-event-exporter
    version: "3.6.3"
    repository: https://charts.bitnami.com/bitnami
EOF

=================================================================================

values.yaml


cat > values.yaml << EOF
kube-prometheus-stack:
  grafana:
    enabled: false
  alertmanager:
    alertmanagerSpec:
      nodeSelector:
        role: prometheus
    persistentVolume:
      enabled: false
  prometheus:
    prometheusSpec:
      nodeSelector:
        role: prometheus
      retention: 7d
  nodeExporter:
    enabled: true
  kubeStateMetrics:
    enabled: true

loki-stack:
  loki:
    image:
      tag: 2.9.3
    nodeSelector:
      role: loki
    persistence:
      enabled: false
    config:
      table_manager:
        retention_deletes_enabled: true
        retention_period: 168h
  promtail:
    enabled: true
    daemonset:
      enabled: true
    config:
      clients:
        - url: http://my-observability-loki:3100/loki/api/v1/push

grafana:
  nodeSelector:
    role: prometheus
  adminPassword: admin123
  persistence:
    enabled: false
  service:
    type: ClusterIP
    port: 3000
  datasources:
    datasources.yaml:
      apiVersion: 1
      datasources:
        - name: Prometheus
          type: prometheus
          url: http://prometheus-my-observability-kube-prom-prometheus:9090
          isDefault: true
        - name: Loki
          type: loki
          url: http://my-observability-loki:3100

reloader:
  reloader:
    watchGlobally: true

kubernetes-event-exporter:
  global:
    security:
      allowInsecureImages: true
  image:
    registry: ghcr.io
    repository: resmoio/kubernetes-event-exporter
    tag: latest
  nodeSelector:
    role: app
  config:
    logLevel: info
    logFormat: json
    maxEventAgeSeconds: 3600
    route:
      routes:
        - match:
            - receiver: loki
    receivers:
      - name: loki
        loki:
          url: "http://my-observability-loki:3100/loki/api/v1/push"
EOF

