======================================================================================
Permanent karo:

echo "fs.inotify.max_user_instances=512
fs.inotify.max_user_watches=524288" | sudo tee /etc/sysctl.d/99-kind.conf
sudo sysctl -p /etc/sysctl.d/99-kind.conf

